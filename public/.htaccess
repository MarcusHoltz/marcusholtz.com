# ===============================================================
#  .htaccess â€” marcusholtz.com
# ===============================================================


# -----------------------------------------------
# Security Headers
# -----------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>


# -----------------------------------------------
# Hide Server Info & Directory Listing
# -----------------------------------------------
ServerSignature Off
Options -Indexes


# -----------------------------------------------
# Block Access to Sensitive Files
# -----------------------------------------------
<FilesMatch "(^\.htaccess|^\.htpasswd|^\.env|^\.gitignore|^\.gitmodules|^\.DS_Store|^Thumbs\.db|^\.editorconfig|^\.travis\.yml|^\.dockerignore|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|Gemfile(\.lock)?|nginx\.conf|apache2?\.conf|httpd\.conf|(wp-)?config\.php|config\.(yml|yaml|ini|xml)|settings\.php|database\.php|Dockerfile|docker-compose\.yml|Makefile|.*\.(pem|key|crt|p12|pfx|log|bak|backup|old|orig|tmp|swp|sql|sqlite|db)|php(info|\.ini)|requirements\.txt|Pipfile(\.lock)?)$">
    Require all denied
</FilesMatch>


# -----------------------------------------------
# Rewrites & Redirects
# -----------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve /card directly to curl â€” bypasses all redirects below
    RewriteCond %{HTTP_USER_AGENT} curl [NC]
    RewriteCond %{REQUEST_URI} ^/card/?$ [OR]
    RewriteCond %{REQUEST_URI} ^/photo/$
    RewriteRule ^ - [L]


    # Block common vulnerability scan patterns
    RewriteCond %{QUERY_STRING} (eval\() [NC,OR]
    RewriteCond %{QUERY_STRING} (\.\./) [NC,OR]
    RewriteCond %{QUERY_STRING} (localhost|loopback|127\.0\.0\.1) [NC]
    RewriteRule ^ - [F,L]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Non-www â†’ www (preserves full path + query string)
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Redirect to holtzweb.com domain â€” uncomment when needed
    # RewriteCond %{HTTP_HOST} ^marcusholtz\.com$ [NC,OR]
    # RewriteCond %{HTTP_HOST} ^www\.marcusholtz\.com$ [NC]
    # RewriteCond %{REQUEST_URI} ^/$
    # RewriteRule ^$ https://www.holtzweb.com/ [R=302,L]

</IfModule>


# -----------------------------------------------
# Browser Caching
# -----------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg              "access plus 1 year"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType image/svg+xml          "access plus 1 year"
    ExpiresByType image/gif              "access plus 1 year"
    ExpiresByType image/x-icon           "access plus 1 year"
    ExpiresByType font/woff2             "access plus 1 year"
    ExpiresByType text/css               "access plus 1 month"
    ExpiresByType text/javascript        "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>


# -----------------------------------------------
# Gzip Compression
# -----------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>
